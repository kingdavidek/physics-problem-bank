def make_problem(question, solution, hint, difficulty, marks, level, subject, topic):
    return {
        "question": question,
        "solution": solution,
        "hint": hint,
        "difficulty": difficulty,
        "marks": marks,
        "topic_url": f"/topic/{level}/{subject}/{topic}",
        "topic_name": topic.replace("_", " ").title(),
        "level": level,
        "subject": subject,
        "topic": topic,
    }