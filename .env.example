# Copy this file to `.env` in the project root and fill in your values.
# Loaded automatically when you run `python app.py` — no need to set vars each time.
# `.env` is for local secrets only; do not commit it to git.

# Flask session signing (change for anything public-facing)
# SECRET_KEY=change-me-to-a-long-random-string

# Auth uses Flask-Login with a 30-day "remember me" cookie when enabled at login.

# --- Lesson AI assistant (optional) ---
# LESSON_ASSIST_MOCK=1  → free demo explanations (no API key or credits needed)
# LESSON_ASSIST_ENABLED=0  → turn assistant off entirely

# Demo mode (default for local dev):
LESSON_ASSIST_MOCK=1

# DeepSeek — pay-as-you-go (top up when you want live AI, no monthly subscription)
# LESSON_ASSIST_MOCK=0
# LESSON_ASSIST_PROVIDER=deepseek
# LESSON_ASSIST_API_KEY=your-deepseek-api-key-here
# LESSON_ASSIST_MODEL=deepseek-chat
# LESSON_ASSIST_BASE_URL=https://api.deepseek.com/v1

# OpenAI alternative:
# LESSON_ASSIST_PROVIDER=openai
# LESSON_ASSIST_API_KEY=sk-...
# LESSON_ASSIST_MODEL=gpt-4o-mini

# --- Weekly recap email (optional — see docs/EMAIL_SETUP.md before launch) ---
# Public site URL (required for unsubscribe links in production)
# SITE_URL=https://yourdomain.com

# Enable real sending (leave unset or 0 until DNS + provider are ready)
# MAIL_ENABLED=1
# MAIL_PROVIDER=resend
# MAIL_FROM_EMAIL=noreply@yourdomain.com
# MAIL_FROM_NAME=Problem Bank
# RESEND_API_KEY=re_xxxxxxxx

# SendGrid alternative:
# MAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxx

# SMTP alternative:
# MAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=1

# Dev: print emails to stdout instead of sending
# MAIL_PROVIDER=console

# Skip users with no activity in the last 7 days (default 1)
# EMAIL_DIGEST_SKIP_INACTIVE=1
